		"builtin-modules": "^3.2.0",
		"esbuild": "^0.24.0",
		"happy-dom": "^20.8.4",
		"knip": "latest",
		"markdownlint-cli": "latest",
		"obsidian": "latest",
		"tslib": "2.7.0",
		"typescript": "^5.6.2",
		"vitest": "^4.1.0"
	},
	"dependencies": {
		"@types/tinycolor": "^1.1.27",
