{
	"name": "obsidian-divide-and-conquer",
	"version": "1.0.2",
	"description": "An Obsidian plugin that provides commands for bulk enabling/disabling of plugins. Intended for power users with many plugins.",
	"main": "main.js",
	"scripts": {
		"build": "node .esbuild.mjs",
		"build:production": "npm run build -- production",
		"build:analyze": "npm run build -- analyze",
		"test": "vitest run",
		"test:watch": "vitest",
		"coverage": "vitest run --coverage",
		"lint:md": "markdownlint \"**/*.md\" --ignore node_modules",
		"lint:eslint": "eslint \"src/**/*.ts\"",
		"lint": "npm run lint:md && npm run lint:eslint",
		"lint:fix": "npm run lint:md -- --fix && npm run lint:eslint -- --fix"
	},
	"keywords": [],
	"author": "geoffreysflaminglasersword & Chris Grieser (aka pseudometa)",
	"license": "MIT",
	"devDependencies": {
		"@eslint/js": "^9.23.0",
		"@biomejs/biome": "latest",
		"@types/node": "^22.5.5",
		"@vitest/coverage-v8": "^4.1.0",
		"builtin-modules": "^3.2.0",
		"esbuild": "^0.24.0",
		"happy-dom": "^20.8.4",
		"eslint": "^9.23.0",
		"globals": "^16.0.0",
		"knip": "latest",
		"markdownlint-cli": "latest",
		"obsidian": "latest",
		"tslib": "2.7.0",
		"typescript": "^5.6.2",
		"typescript-eslint": "^8.27.0",
		"vitest": "^4.1.0"
	},
	"dependencies": {
		"@types/tinycolor": "^1.1.27",
		"monkey-around": "^3.0.0",
		"tinycolor2": "^1.4.2",
		"typescript-super-set": "^1.0.0"
	}
}
